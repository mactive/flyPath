{
  "name": "flight-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --import tsx server/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:client": "tsc --noEmit && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start:server": "node server-dist/index.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "d3-geo": "^3.1.1",
    "d3-geo-projection": "^4.0.0",
    "hono": "^4.12.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.160.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.160.0",
    "@types/topojson-client": "^3.1.4",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "vite": "^5.4.10"
  }
}
